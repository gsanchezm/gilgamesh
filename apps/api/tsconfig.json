{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2021",
    "lib": ["ES2023"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "types": ["node"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@gilgamesh/domain": ["../../packages/domain/src/index.ts"],
      "@gilgamesh/application": ["../../packages/application/src/index.ts"]
    }
  },
  "include": ["src", "test"]
}
