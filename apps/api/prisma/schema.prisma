// Gilgamesh — applied Prisma schema (slice 1 subset of the data-model contract).
// The full contract lives at specs/data-model/schema.prisma; later slices add the
// remaining models (Feature, Scenario, TestCase, Run, RunNode, Artifact, Integration,
// KnowledgeDoc/Chunk) via incremental migrations.
//
// IDs and timestamps are assigned by the application layer (Uuid7IdGenerator / Clock),
// so columns carry no Prisma @default — the records arrive fully populated. citext is
// pre-installed in the database (docker/postgres/init.sql).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum ProjectFormat {
  BDD
  TRADITIONAL
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum RepoProvider {
  github
  gitlab
  bitbucket
  ado
}

enum IntegrationGroup {
  SOURCE_REPOS
  PROJECT_TRACKING
  TEST_MANAGEMENT
  COMMUNICATION
  CICD
  DEVICES_BROWSERS
}

enum AgentSlot {
  lead
  arch
  manual
  web
  api
  android
  ios
  perf
  visual
  sec
  a11y
}

enum AgentFamily {
  proceso
  ui
  backend
  guardian
}

enum Plan {
  TEAM
  PRO
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum TestCasePriority {
  HIGH
  MEDIUM
  LOW
}

enum TestCaseStatus {
  NOTRUN
  PASS
  FAIL
  BLOCKED
  SKIPPED
}

model Org {
  id        String   @id @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")

  memberships  Membership[]
  projects     Project[]
  slices       Slice[]
  agents       Agent[]
  toolBindings ToolBinding[]
  features     Feature[]
  testCases    TestCase[]
  runs         Run[]
  subscription Subscription?
  auditLogs    AuditLog[]
  integrations Integration[]
  knowledgeDocuments KnowledgeDocument[]
  knowledgeChunks    KnowledgeChunk[]

  @@map("orgs")
}

model User {
  id           String     @id @db.Uuid
  // App normalizes emails to lowercase (domain Email VO), so a plain unique text column
  // gives case-insensitive uniqueness without the citext extension.
  email        String     @unique
  passwordHash String     @map("password_hash")
  firstName    String     @map("first_name")
  middleName   String?    @map("middle_name")
  lastName     String     @map("last_name")
  status       UserStatus
  createdAt    DateTime   @map("created_at")
  updatedAt    DateTime   @map("updated_at")

  memberships Membership[]
  sessions    Session[]
  auditEvents AuditLog[]   @relation("AuditLogActor")

  @@map("users")
}

model Membership {
  id        String   @id @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      Role
  createdAt DateTime @map("created_at")

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@map("memberships")
}

model Session {
  id        String    @id @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  ip        String?
  userAgent String?   @map("user_agent")
  createdAt DateTime  @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Project {
  id           String        @id @db.Uuid
  orgId        String        @map("org_id") @db.Uuid
  name         String
  slug         String
  format       ProjectFormat
  repoProvider RepoProvider? @map("repo_provider")
  repoFullName String?       @map("repo_full_name")
  repoBranch     String?     @map("repo_branch")
  repoCommit     String?     @map("repo_commit")
  repoLastSyncAt DateTime?   @map("repo_last_sync_at")
  createdAt    DateTime      @map("created_at")
  updatedAt    DateTime      @map("updated_at")

  org          Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  slices       Slice[]
  toolBindings ToolBinding[]
  features     Feature[]
  testCases    TestCase[]
  runs         Run[]

  @@unique([orgId, slug])
  @@map("projects")
}

model Slice {
  id        String @id @db.Uuid
  orgId     String @map("org_id") @db.Uuid
  projectId String @map("project_id") @db.Uuid
  key       String
  name      String
  order     Int

  org       Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  features  Feature[]
  testCases TestCase[]

  @@unique([projectId, key])
  @@index([orgId])
  @@map("slices")
}

model Agent {
  id          String      @id @db.Uuid
  orgId       String      @map("org_id") @db.Uuid
  slot        AgentSlot
  deityName   String      @map("deity_name")
  role        String
  family      AgentFamily
  glyph       String
  culture     String
  defaultTool String      @map("default_tool")
  createdAt   DateTime    @map("created_at")

  org          Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  toolBindings ToolBinding[]
  testCases    TestCase[]

  @@unique([orgId, slot])
  @@map("agents")
}

model ToolBinding {
  id        String   @id @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  agentId   String   @map("agent_id") @db.Uuid
  tool      String
  enabled   Boolean
  updatedAt DateTime @map("updated_at")

  org     Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([projectId, agentId])
  @@index([orgId])
  @@index([agentId])
  @@map("tool_bindings")
}

model Subscription {
  id                     String             @id @db.Uuid
  orgId                  String             @unique @map("org_id") @db.Uuid
  plan                   Plan
  billingCycle           BillingCycle       @map("billing_cycle")
  seats                  Int
  status                 SubscriptionStatus
  runMinutesQuota        Int                @map("run_minutes_quota")
  runMinutesUsed         Int                @map("run_minutes_used")
  providerCustomerId     String?            @map("provider_customer_id")
  providerSubscriptionId String?            @map("provider_subscription_id")
  currentPeriodEnd       DateTime?          @map("current_period_end")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model AuditLog {
  id          String   @id @db.Uuid
  // Nullable: non-org-scoped events (auth.register / auth.login) are recorded before a tenant exists.
  orgId       String?  @map("org_id") @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  metadata    Json
  ip          String?
  createdAt   DateTime @map("created_at")

  org   Org?  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor User? @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([orgId, createdAt(sort: Desc)])
  @@index([actorUserId])
  @@map("audit_logs")
}

model Feature {
  id        String   @id @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  sliceId   String?  @map("slice_id") @db.Uuid
  name      String
  path      String
  content   String
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")

  org       Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slice     Slice?     @relation(fields: [sliceId], references: [id], onDelete: SetNull)
  scenarios Scenario[]

  @@unique([projectId, path])
  @@index([projectId])
  @@index([orgId])
  @@map("features")
}

model Scenario {
  id         String          @id @db.Uuid
  orgId      String          @map("org_id") @db.Uuid
  featureId  String          @map("feature_id") @db.Uuid
  name       String
  order      Int
  lastStatus TestCaseStatus? @map("last_status")

  feature Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@index([featureId])
  @@map("scenarios")
}

model TestCase {
  id              String           @id @db.Uuid
  orgId           String           @map("org_id") @db.Uuid
  projectId       String           @map("project_id") @db.Uuid
  sliceId         String?          @map("slice_id") @db.Uuid
  key             String
  title           String
  steps           String
  data            String
  expected        String
  priority        TestCasePriority
  status          TestCaseStatus
  assignedAgentId String?          @map("assigned_agent_id") @db.Uuid
  createdAt       DateTime         @map("created_at")
  updatedAt       DateTime         @map("updated_at")

  org     Org     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slice   Slice?  @relation(fields: [sliceId], references: [id], onDelete: SetNull)
  agent   Agent?  @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)

  @@unique([projectId, key])
  @@index([projectId])
  @@index([orgId])
  @@map("test_cases")
}

enum RunStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
  CANCELED
}

enum RunTrigger {
  MANUAL
  SCHEDULE
  CI
}

enum RunTargetKind {
  FEATURE
  TESTCASE
}

enum ResultStatus {
  PASS
  FAIL
  SKIP
}

model Run {
  id          String        @id @db.Uuid
  orgId       String        @map("org_id") @db.Uuid
  projectId   String        @map("project_id") @db.Uuid
  status      RunStatus
  trigger     RunTrigger
  targetKind  RunTargetKind @map("target_kind")
  targetId    String        @map("target_id") @db.Uuid
  runLabel    String?       @map("run_label")
  passed      Int?
  failed      Int?
  skipped     Int?
  total       Int?
  ratePct     Int?          @map("rate_pct")
  durationMs  Int?          @map("duration_ms")
  createdById String        @map("created_by_id") @db.Uuid
  startedAt   DateTime?     @map("started_at")
  finishedAt  DateTime?     @map("finished_at")
  createdAt   DateTime      @map("created_at")

  org     Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  results RunResult[]

  @@index([projectId, createdAt(sort: Desc)])
  @@index([orgId])
  @@map("runs")
}

model RunResult {
  id     String       @id @db.Uuid
  orgId  String       @map("org_id") @db.Uuid
  runId  String       @map("run_id") @db.Uuid
  refId  String       @map("ref_id") @db.Uuid
  name   String
  status ResultStatus
  log    String[]
  order  Int

  run Run @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("run_results")
}

// Slice 5: the GLOBAL shared knowledge base (owner decision S5-A) — no orgId, retrieval is shared
// across all orgs. `embedding` is a pgvector column (Unsupported → written/queried via raw SQL in
// PrismaKnowledgeChunkRepository). The id is the corpus chunk id (text, not a UUID).
model KnowledgeChunk {
  id            String                      @id
  // Null for the GLOBAL shared corpus (S5-A); set for per-org uploaded documents (slice 7) so the
  // shared search can exclude them (WHERE org_id IS NULL) — no cross-org leak.
  orgId         String?                     @map("org_id") @db.Uuid
  documentId    String?                     @map("document_id") @db.Uuid
  source        String
  headingPath   String[]                    @map("heading_path")
  section       String
  content       String
  embedding     Unsupported("vector(1536)")
  tokenEstimate Int                         @map("token_estimate")

  // Per-org uploaded chunks are referentially tied to their org + document (audit #2). Both are
  // nullable (the GLOBAL shared corpus has neither) and cascade so cleanup can't leave orphans.
  org      Org?              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  document KnowledgeDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([documentId])
  @@index([orgId, documentId])
  @@map("knowledge_chunks")
}

model KnowledgeDocument {
  id         String   @id @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  name       String
  type       String
  chunkCount Int      @map("chunk_count")
  createdAt  DateTime @default(now()) @map("created_at")

  org    Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  chunks KnowledgeChunk[]

  @@index([orgId, createdAt])
  @@map("knowledge_documents")
}

model Integration {
  id            String           @id @db.Uuid
  orgId         String           @map("org_id") @db.Uuid
  key           String
  group         IntegrationGroup
  connected     Boolean
  secretRef     String?          @map("secret_ref")
  config        Json
  connectedById String?          @map("connected_by_id") @db.Uuid
  connectedAt   DateTime?        @map("connected_at")

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
  @@map("integrations")
}
