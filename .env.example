# Gilgamesh — local environment example. Copy to .env (gitignored).
NODE_ENV=development

# Postgres (docker-compose: `docker compose up -d postgres`)
DATABASE_URL=postgresql://gilgamesh:gilgamesh@localhost:5432/gilgamesh?schema=public

# API
API_PORT=3001
# Comma-separated browser origin allowlist for CORS (empty = same-origin only)
CORS_ORIGINS=http://localhost:5173
# 32+ byte secret used to sign/verify session cookies (generate your own)
SESSION_SECRET=change-me-in-a-real-environment-please-32b

# Secret vault (slice 20 — SECURITY INVERSION: the API refuses to boot without one of these).
# Real vault: AZURE_KEY_VAULT_URL=https://<name>.vault.azure.net (DefaultAzureCredential).
# Dev/test only: VAULT_MODE=offline opts in to the in-memory stub (refused when NODE_ENV=production).
# Note: the API does not read .env files — export this in the shell that runs start:dev.
VAULT_MODE=offline

# Web
VITE_API_BASE_URL=http://localhost:3001/api/v1
