{
  "name": "gilgamesh",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Gilgamesh — a multi-tenant QA platform where deity-agents plan, author and run tests.",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:bdd": "turbo run test:bdd",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0"
  }
}
